# =============================================================================
# Hewane Dashboard — Environment Variables
# Copy to `.env.local` for local development:  cp .env.example .env.local
# =============================================================================

# --- Required: authentication (Better Auth + PostgreSQL) -----------------------

DATABASE_URL=postgresql://hewane:hewane_dev_password@localhost:5432/hewane_dashboard

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Must match the URL you use in the browser
BETTER_AUTH_URL=http://localhost:3000

# Used for SEO metadata, sitemap, and Open Graph (usually same as BETTER_AUTH_URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Seed first admin when running `pnpm db:setup`
ADMIN_EMAIL=admin@hewaneschoolofmusic.com
ADMIN_PASSWORD=change-me-to-a-strong-password
ADMIN_NAME=Hewane Admin

# Set true in production after the admin account exists
DISABLE_SIGNUP=false

# --- Required: Google Sheets -------------------------------------------------

# Primary config file (multi-sheet). Edit sheets.config.json in the project root.
# Share every spreadsheet listed there with the service account email below.

GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=

# Optional legacy fallback if sheets.config.json is missing (single spreadsheet ID)
# GOOGLE_SHEETS_ID=

# Optional JSON merge on top of sheets.config.json:
# GOOGLE_SHEETS_CONFIG={"contacts":[{"spreadsheetId":"...","tab":"Sheet1","schema":"google-contacts"}]}

# --- Required for sync & broadcast: n8n webhooks -----------------------------
#
# IMPORTANT — env var names vs n8n export file names:
#   N8N_WORKFLOW_A_URL  →  webhook path hewane-sheets-sync
#                          →  import "Hewane – Workflow B_ Multi-Sheet Sync.json"
#   N8N_WORKFLOW_B_URL  →  webhook path hewane-broadcast-trigger
#                          →  import "Hewane – Workflow A_ Whatsapp Broadcast message.json"
#
# Workflow JSON location (sibling to Dashboard repo):
#   ../workflows/Hewane – Workflow A_ Whatsapp Broadcast message.json
#   ../workflows/Hewane – Workflow B_ Multi-Sheet Sync.json

N8N_WORKFLOW_A_URL=https://your-n8n-host/webhook/hewane-sheets-sync
N8N_WORKFLOW_B_URL=https://your-n8n-host/webhook/hewane-broadcast-trigger
N8N_BASE_URL=https://your-n8n-host

# Optional: pause/stop running broadcasts via n8n REST API
N8N_API_KEY=
